# Email Service Configuration - Resend Only

# Resend (3,000 emails/month + 100/day limit)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here

# Business Email (where form submissions will be sent)
BUSINESS_EMAIL=info@calgarycityroofing.com

# From Email (use your domain or default for testing)
FROM_EMAIL=onboarding@resend.dev