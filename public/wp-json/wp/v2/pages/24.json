tainer elementor-column-gap-default\">\n\t\t\t\t\t<div class=\"elementor-column elementor-col-25 elementor-inner-column elementor-element elementor-element-38ad7d40\" data-id=\"38ad7d40\" data-element_type=\"column\">\n\t\t\t<div class=\"elementor-widget-wrap elementor-element-populated\">\n\t\t\t\t\t\t<div class=\"elementor-element elementor-element-2fa67cda elementor-position-top elementor-widget elementor-widget-global elementor-global-380 elementor-widget-image-box\" data-id=\"2fa67cda\" data-element_type=\"widget\" data-widget_type=\"image-box.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t<div class=\"elementor-image-box-wrapper\"><figure class=\"elementor-image-box-img\"><img decoding=\"async\" width=\"204\" height=\"231\" src=\"https:\/\/www.calgarycityroofing.com\/wp-content\/uploads\/2018\/08\/no-subcontractors-icon.png\" class=\"elementor-animation-grow attachment-full size-full wp-image-240\" alt=\"no-subcontractors-icon\" \/><\/figure><div class=\"elementor-image-box-content\"><p class=\"elementor-image-box-title\">We are 100% in-house staff; we do not use ANY subcontractors.<\/p><p class=\"elementor-image-box-description\">This allows us to maintain complete control of scheduling, workmanship and clean up after your roof repairs or replacement is completed.<\/p><\/div><\/div>\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/div>\n\t\t<\/div>\n\t\t\t\t<div class=\"elementor-column elementor-col-25 elementor-inner-column elementor-element elementor-element-44538283\" data-id=\"44538283\" data-element_type=\"column\">\n\t\t\t<div class=\"elementor-widget-wrap elementor-element-populated\">\n\t\t\t\t\t\t<div class=\"elementor-element elementor-element-531d102d elementor-position-top elementor-widget elementor-widget-global elementor-global-383 elementor-widget-image-box\" data-id=\"531d102d\" data-element_type=\"widget\" data-widget_type=\"image-box.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t<div class